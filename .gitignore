# Canvas course mirrors — generated by --init and --pull, never committed
course/
blueprint_course/

# Markdown workspace — generated from course/ by --build, never committed
course_src/

# Canvas ID indexes and push logs — course-specific, never committed
.canvas/

# Secrets and local config
.env
.env.local
.env.*.local
# Per-user runbooks / local-only docs (e.g. PAT rotation log). Anything
# ending in `.local.md` stays local. Use this for files that contain
# specific dates / instance IDs / personal account references that
# shouldn't be in the public repo.
*.local.md

# AI coding tool local memory / caches — per-user, never committed
.gemini/
.claude/cache/
.cursor/
.aider*

# Dev tools — maintainer-only scripts for managing the toolkit itself
# (e.g. add_roadmap_feature.py for updating voting system)
lib/tools/add_roadmap_feature.py

# Dev docs — maintainer-only documentation (deployment, architecture, credentials)
# AGENTS.md is public/committed; docs/dev/ is private/gitignored
docs/dev/

# GitHub issues workflow — local only
.github_issues/

# Local dev-only tools — sandbox/testing utilities, NOT shipped to consumers.
# clean_sandbox.py wipes CANVAS_SANDBOX_EMPTY_ID's content for repeatable import
# tests; it's tied to the maintainer's sandbox, so it stays local (+ its test).
lib/tools/clean_sandbox.py
lib/tests/test_clean_sandbox.py

# gh-issues-agent — local clone of upstream tool used during development.
# Populate with: git clone https://github.com/chaz-clark/gh_issues_agent.git gh-issues-agent
# Update with:   cd gh-issues-agent && git pull origin main
gh-issues-agent/

# make-ai-agents — local clone of upstream tool used during development.
# Populate with: git clone https://github.com/chaz-clark/Make-AI-Agents.git make-ai-agents
# Update with:   cd make-ai-agents && git pull origin main
Make-AI-Agents/

# handoff — local clone of upstream tool used during development.
# Note: distinct from `handoffs/` (plural) which is local-only handoff scratch.
# Populate with: git clone https://github.com/chaz-clark/handoff.git
# Update with:   cd handoff && git pull origin main
handoff/

# Quality reports — generated output
quality_report.md

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# Rust build artifacts
**/target/
**/*.rs.bk
**/Cargo.lock

# macOS
.DS_Store
knowledge/medium_draft_*.md

# Raw source materials distilled into lib/agents/knowledge/ — local only
lib/agents/pre_knowledge/

# Local-only artifacts (answer keys, drafts, notes) — created by --pull, never committed
course_ref/

# Local Agent to Agent Handoff files — local only
handoffs/

# ─────────────────────────────────────────────────────────────────────────────
# FERPA defense-in-depth — issue #44 (2026-06-11 ds250-onln-master incident)
#
# Mirrors scaffold/grading/.gitignore (the consumer-side gate) so that if an
# operator misconfigures cwd (e.g. `uv run --directory canvas-toolbox`),
# relative `--challenge-dir grading/...` lands inside the toolkit clone, and
# PII files cannot be `git add -A`ed into the public canvas-toolbox repo.
#
# This is BELT — the SUSPENDERS is `_challenge_dir_guard.py` which refuses
# to write inside the toolkit install dir in the first place. Both together
# make the FERPA leak surface defense in depth.
# ─────────────────────────────────────────────────────────────────────────────
/grading/
**/submissions_raw/
**/submissions_deid/
**/_raw/
**/_deid/
**/.keymap.json
**/.known_names.txt
**/.fetch_log.json
**/_existing_grades.csv
**/assignment_spec.md
**/UNIQUE_GROUP_MEMOS.md
**/feedback/
**/.review.csv
**/.review*.csv
**/.push_log.md
**/.mark_reviewed
