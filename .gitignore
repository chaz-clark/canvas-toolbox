# Canvas course mirrors — generated by --init and --pull, never committed
course/
blueprint_course/

# Markdown workspace — generated from course/ by --build, never committed
course_src/

# Canvas ID indexes and push logs — course-specific, never committed
.canvas/

# Secrets and local config
.env

# AI coding tool local memory / caches — per-user, never committed
.gemini/
.claude/cache/
.cursor/
.aider*

# GitHub issues workflow — local only
.github_issues/

# gh-issues-agent — local clone of upstream tool used during development.
# Populate with: git clone https://github.com/chaz-clark/gh_issues_agent.git gh-issues-agent
# Update with:   cd gh-issues-agent && git pull origin main
gh-issues-agent/

# make-ai-agents — local clone of upstream tool used during development.
# Populate with: git clone https://github.com/chaz-clark/Make-AI-Agents.git make-ai-agents
# Update with:   cd make-ai-agents && git pull origin main
make-ai-agents/

# handoff — local clone of upstream tool used during development.
# Note: distinct from `handoffs/` (plural) which is local-only handoff scratch.
# Populate with: git clone https://github.com/chaz-clark/handoff.git
# Update with:   cd handoff && git pull origin main
handoff/

# Quality reports — generated output
quality_report.md

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# macOS
.DS_Store
knowledge/medium_draft_*.md

# Raw source materials distilled into lib/agents/knowledge/ — local only
lib/agents/pre_knowledge/

# Local-only artifacts (answer keys, drafts, notes) — created by --pull, never committed
course_ref/

# Local Agent to Agent Handoff files — local only
handoffs/
